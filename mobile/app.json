{
  "expo": {
    "name": "JpWords",
    "slug": "jpwords",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "plugins": ["react-native-iap"],
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jpwords.mobile"
    },
    "android": {
      "package": "com.jpwords.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "edition": "standalone-free"
    }
  }
}
