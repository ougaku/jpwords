{
  "name": "jpwords-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:ads-config": "node scripts/validate-ads-config.js",
    "validate:ads-production": "node scripts/validate-ads-config.js --strict-production",
    "build:android-cn": "eas build --platform android --profile android-cn",
    "build:android-global": "eas build --platform android --profile android-global",
    "build:ios": "eas build --platform ios --profile ios-universal",
    "build:android-cn:production": "eas build --platform android --profile android-cn-production",
    "build:android-global:production": "eas build --platform android --profile android-global-production",
    "build:ios:production": "eas build --platform ios --profile ios-universal-production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "expo": "^54.0.0",
    "expo-dev-client": "^56.0.20",
    "expo-sqlite": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.2.7",
    "react-native": "^0.81.0",
    "react-native-iap": "^15.3.2",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.9.0"
  }
}
